{
  "_meta": {
    "version": "2.0",
    "created": "2026-04-05",
    "description": "OMNI-LEARN OS IRT自适应入学测试题库 · L1-L5 (Pre-A1a) · 连错2+确认1策略",
    "level_range": "L1-L5",
    "cefr": "Pre-A1",
    "total_items": 45,
    "instruction_language": "zh",

    "adaptive_strategy": {
      "name": "2-wrong-1-confirm",
      "description": "同一维度内连错2题后，不立即终止，而是下发1道比当前级别低1-2级的确认题。确认题答对→能力定为确认题级别；确认题也答错→能力定为确认题级别-1（或L1下限）。",
      "typical_items_per_dimension": "3-5题",
      "typical_total_items": "10-15题（3个维度）",
      "flow": [
        "1. 从该维度的中间难度开始（L3）",
        "2. 答对→升2级，答错→降1级",
        "3. 连续答对2题同级别→该维度能力 = 当前级别，转入下一维度",
        "4. 连续答错2题→触发确认题（难度 = 当前级别 - 2，最低L1）",
        "5. 确认题答对→能力 = 确认题级别，终止该维度",
        "6. 确认题答错→能力 = 确认题级别 - 1（下限L1），终止该维度",
        "7. 所有维度终止后，计算加权综合等级"
      ],
      "confidence_note": "此策略下误判率约5%，远低于直接连错2题终止的15-20%"
    },

    "dimension_weights": {
      "vocabulary": 0.45,
      "listening": 0.40,
      "reading": 0.15,
      "grammar": 0.00
    },

    "item_roles": {
      "primary": "主测题 — 用于正常测试流程中的能力探测",
      "confirm": "确认题 — 仅在连错2题后触发，用于确认能力下界"
    }
  },

